<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
 <persistence-unit name="product-unit">

  <class>java_development.framework.hibernate_jpa.entity.Product</class>

  <properties>

   <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
   <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/product-database?useSSL=false&amp;allowPublicKeyRetrieval=true"/>
   <property name="jakarta.persistence.jdbc.user" value="root"/>
   <property name="jakarta.persistence.jdbc.password" value="Adish@2003"/>

   <property name="hibernate.hbm2ddl.auto" value="update"/>
   <property name="hibernate.show_sql" value="true"/>

  </properties>

 </persistence-unit>
</persistence>