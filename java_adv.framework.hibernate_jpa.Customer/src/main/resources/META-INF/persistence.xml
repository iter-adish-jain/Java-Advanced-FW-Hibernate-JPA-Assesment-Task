<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
          https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
          version="3.0">


<persistence-unit name="employee-unit">

    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <!-- Entity Classes -->
    <class>com.capgemini.java_dev.framework.hibernate.jpa.entity.Customer</class>

    <properties>

        <!-- Database Connection -->
        <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
        <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/customer-db"/>
        <property name="jakarta.persistence.jdbc.user" value="root"/>
        <property name="jakarta.persistence.jdbc.password" value="Adish@2003"/>

        <!-- Hibernate Dialect -->
        <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>

        <!-- Schema Generation -->
        <property name="hibernate.hbm2ddl.auto" value="update"/>

        <!-- SQL Logging -->
        <property name="hibernate.show_sql" value="true"/>
        <property name="hibernate.format_sql" value="true"/>

    </properties>

</persistence-unit>


</persistence>
